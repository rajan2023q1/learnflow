# LearnFlow backend configuration. Copy to `.env` and adjust.

ENVIRONMENT=development
DEBUG=true

# --- Database ---------------------------------------------------------------
# SQLite (zero-config default):
DATABASE_URL=sqlite+aiosqlite:///./learnflow.db
# Postgres 17 (production target):
# DATABASE_URL=postgresql+asyncpg://learnflow:learnflow@localhost:5432/learnflow

# Auto-create tables on startup (dev). Set false in managed envs and run
# `alembic upgrade head` instead.
DB_AUTO_CREATE=true

# Behind a trusted reverse proxy? Enable to read the client IP from
# X-Forwarded-For (do NOT enable if not actually behind such a proxy).
TRUST_PROXY=false

# --- JWT (RS256) ------------------------------------------------------------
# Leave unset in dev to auto-generate keys under keys/. In production, supply
# real keys via files (paths below) or inline PEM env vars.
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
JWT_ISSUER=learnflow

# --- Refresh cookie ---------------------------------------------------------
# Set COOKIE_SECURE=false for local HTTP development; true (default) needs HTTPS.
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# --- Client / email ---------------------------------------------------------
FRONTEND_URL=http://localhost:5173
EMAIL_FROM=no-reply@learnflow.example
